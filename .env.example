# Stream-Server S1 Spike — local env example
# Copy this file to `.env` (which is gitignored) and fill in real values.
# Do NOT commit `.env`.

# RTSPS source URL of the UniFi Intercom video feed.
# The path id and the embedded token are unique per camera and per deployment.
# Format: rtsps://HOST:7441/<feed-id>?enableSrtp
CARVILON_STREAM_RTSP_SOURCE=rtsps://HOST:7441/REPLACE_ME?enableSrtp

# HTTP listen address for signaling + test page.
# Free to choose, but do NOT collide with carvilon-server (9080) or go2rtc (1984).
CARVILON_STREAM_LISTEN=:8555
