# Stream-Server S1 Spike — local env example
# Copy this file to `.env` (which is gitignored) and fill in real values.
# Do NOT commit `.env`. The API key in particular must never reach the repo.

# UniFi Protect API host (the UDM running Protect).
UNIFI_NVR_HOST=192.168.1.1

# UniFi Protect *integration* API key. Create under:
#   UniFi → Settings → Control Plane → Integrations → Create API Key
# Required scope: cameras / streams. NEVER commit a real value.
UNIFI_API_KEY=REPLACE_ME

# OPTIONAL since S6-03 — protect camera identifier (the long hex string
# from the camera list, also visible in the Protect UI URL).
#
# Seed priority on an empty DB (cmd/spike only — the carvilon-side
# streambackend Naht stays empty-start regardless):
#
#   1. CARVILON_PROFILES_JSON set       -> JSON wins.
#   2. UNIFI_CAMERA_ID set               -> S6 measurement set on THIS camera.
#   3. neither set                       -> S6 measurement set on the
#                                           built-in intercom CameraID
#                                           (see defaultIntercomCameraID
#                                           in cmd/spike/main.go).
#
# Set this when you want the measurement set on a different physical
# camera; leave blank for the intercom default.
# UNIFI_CAMERA_ID=REPLACE_ME

# Optional: full multi-camera / multi-profile configuration as a JSON
# array. When set, this overrides the single-camera default-set logic
# above and lets you address any number of cameras at any number of
# qualities, usages and codecs.
#
# Required per entry (S6-09: same field names as GET /api/profiles
# and PUT /api/profiles/{name} use — snake_case):
#   name           — the value clients pass in ?src=<name>
#   camera_id      — UniFi Protect camera identifier
#   quality        — "high" | "medium" | "low"
#   usage          — "browser" | "esp"
#   codec          — "h264_passthrough" | "mjpeg" | "h264_cbp"
#                    NB: codec=h264_passthrough is the only codec served
#                    via /offer (WebRTC); mjpeg goes to /api/stream.mjpeg,
#                    h264_cbp goes to /stream/h264.
#
# Required for codec="mjpeg" or "h264_cbp" (transcoded codecs):
#   width, height, fps
#   encode_quality — for mjpeg: ffmpeg -q:v, 1=best..31=worst (4-8 typical)
#                    for h264_cbp: libx264 CRF, 0=best..51=worst (22-30 typical)
#
# Optional:
#   description — shown in the admin UI; log-only otherwise
#
# h264_passthrough ignores width/height/fps/encode_quality (the camera
# dictates the wire shape).
#
# Note: the seed JSON unmarshal is case-insensitive (Go's default), so
# old configs using camelCase (cameraID / encodeQuality) keep working.
# New configs should use snake_case to match the HTTP API.
#
# Example (S6-01 default-set + extra camera):
# CARVILON_PROFILES_JSON='[
#   {"name":"intercom_browser","camera_id":"679573e1...","quality":"high","usage":"browser","codec":"h264_passthrough","description":"Intercom (browser)"},
#   {"name":"mjpeg_hq",        "camera_id":"679573e1...","quality":"high","usage":"esp","codec":"mjpeg","width":800,"height":1280,"fps":9,"encode_quality":4,"description":"ESP MJPEG HQ"},
#   {"name":"mjpeg_bal",       "camera_id":"679573e1...","quality":"high","usage":"esp","codec":"mjpeg","width":800,"height":1280,"fps":12,"encode_quality":6,"description":"ESP MJPEG balanced"},
#   {"name":"mjpeg_fast",      "camera_id":"679573e1...","quality":"high","usage":"esp","codec":"mjpeg","width":640,"height":1024,"fps":15,"encode_quality":8,"description":"ESP MJPEG fast"},
#   {"name":"h264_cbp",        "camera_id":"679573e1...","quality":"high","usage":"esp","codec":"h264_cbp","width":800,"height":1280,"fps":12,"encode_quality":26,"description":"ESP H.264 CBP"},
#   {"name":"ai360_browser",   "camera_id":"68abcd...",  "quality":"high","usage":"browser","codec":"h264_passthrough","description":"AI 360"}
# ]'

# Optional: wire-protection mode for the camera-to-server hop.
# "tls"  (default) — TLS tunnel via rtsps://, plain RTP inside.
#                    Same security posture as the go2rtc rtspx:// path.
# "srtp" — RESERVED for a future MIKEY+SRTP implementation; today this
#          returns an error at startup. The switch exists so the
#          configuration shape is stable across the planned upgrade.
# UNIFI_ENCRYPTION=tls

# Optional: HTTP listen address for signaling + test page.
# Free to choose, but do NOT collide with carvilon-server (9080) or go2rtc (1984).
CARVILON_STREAM_LISTEN=:8555

# Optional: path to the ffmpeg binary used by the MJPEG encoder.
# Defaults to "ffmpeg" (resolved via $PATH).
# CARVILON_FFMPEG=/usr/bin/ffmpeg

# Optional: disable MJPEG output entirely (set to a non-empty value).
# By default, MJPEG is enabled and the server fails fast at startup if
# ffmpeg is not installed. Set this for WebRTC-only dev runs on machines
# without ffmpeg.
# CARVILON_DISABLE_MJPEG=1

# Optional: path to the SQLite profile database. The parent directory
# is created on first start. Defaults to ./state/stream.db (gitignored).
#
# S5 rule: once this DB has any profiles, CARVILON_PROFILES_JSON is
# IGNORED at startup. The DB is the source of truth. Delete the file
# (or use `:memory:` in dev) to re-seed from JSON.
# CARVILON_STREAM_DB=./state/stream.db

# Optional: the absolute base URL the StreamBackend uses when building
# MJPEGURL / WebRTCSignalURL responses for the carvilon-side proxy.
# Defaults to "http://127.0.0.1" + CARVILON_STREAM_LISTEN.
# CARVILON_STREAM_BASE_URL=http://127.0.0.1:8555
