# Stream-Server S1 Spike — local env example
# Copy this file to `.env` (which is gitignored) and fill in real values.
# Do NOT commit `.env`. The API key in particular must never reach the repo.

# UniFi Protect API host (the UDM running Protect).
UNIFI_NVR_HOST=192.168.1.1

# UniFi Protect *integration* API key. Create under:
#   UniFi → Settings → Control Plane → Integrations → Create API Key
# Required scope: cameras / streams. NEVER commit a real value.
UNIFI_API_KEY=REPLACE_ME

# Protect camera identifier (the long hex string from the camera list,
# also visible in the Protect UI URL).
#
# This is the BACKWARD-COMPATIBLE single-camera mode: when set, the
# binary registers two default profiles ("intercom_browser" + "intercom_esp")
# on this one camera. For multi-camera setups, leave this unset and
# use CARVILON_PROFILES_JSON below instead.
UNIFI_CAMERA_ID=REPLACE_ME

# Optional: full multi-camera / multi-profile configuration as a JSON
# array. When set, this overrides the single-camera default-pair logic
# above and lets you address any number of cameras at any number of
# qualities and usages.
#
# Each entry has: name, cameraID, quality (high|medium|low),
# usage (browser|esp), description (optional).
#
# Names are the values clients pass in ?src=<name> at /offer (for
# browser usage) or /api/stream.mjpeg (for esp usage).
#
# Example:
# CARVILON_PROFILES_JSON='[
#   {"name":"intercom_browser","cameraID":"679573e1...","quality":"high","usage":"browser","description":"Intercom"},
#   {"name":"intercom_esp",    "cameraID":"679573e1...","quality":"high","usage":"esp"},
#   {"name":"ai360_browser",   "cameraID":"68abcd...",  "quality":"high","usage":"browser","description":"AI 360"}
# ]'

# Optional: wire-protection mode for the camera-to-server hop.
# "tls"  (default) — TLS tunnel via rtsps://, plain RTP inside.
#                    Same security posture as the go2rtc rtspx:// path.
# "srtp" — RESERVED for a future MIKEY+SRTP implementation; today this
#          returns an error at startup. The switch exists so the
#          configuration shape is stable across the planned upgrade.
# UNIFI_ENCRYPTION=tls

# Optional: HTTP listen address for signaling + test page.
# Free to choose, but do NOT collide with carvilon-server (9080) or go2rtc (1984).
CARVILON_STREAM_LISTEN=:8555

# Optional: path to the ffmpeg binary used by the MJPEG encoder.
# Defaults to "ffmpeg" (resolved via $PATH).
# CARVILON_FFMPEG=/usr/bin/ffmpeg

# Optional: disable MJPEG output entirely (set to a non-empty value).
# By default, MJPEG is enabled and the server fails fast at startup if
# ffmpeg is not installed. Set this for WebRTC-only dev runs on machines
# without ffmpeg.
# CARVILON_DISABLE_MJPEG=1
