# go2rtc configuration example for carvilon (Saison 14-01).
#
# Place this file at the path go2rtc reads on startup (usually
# /usr/local/etc/go2rtc.yaml on the RPi). The carvilon-server
# /a/streams admin page edits the same surface via the REST API,
# so once go2rtc is running you typically do not need to hand-edit
# this file again - it is here as a known-good starting point.
#
# Three profiles are pre-populated:
#
#   intercom_high      - the source profile. Point this at your
#                        actual UA Intercom RTSPS feed (the URL
#                        comes from the UA Console / Protect side).
#                        intercom_esp and intercom_browser ffmpeg-
#                        derive from it.
#
#   intercom_esp       - 800x1280 MJPEG, 9 FPS, q:v 6. Sweet-spot
#                        from ESP-Saison 2 for the ESP32-P4 board.
#
#   intercom_browser   - 640x1024 MJPEG, 12 FPS, q:v 5. Smaller
#                        for browsers; ruckelfrei on older phones.
#
# The carvilon server proxies /esp/stream.mjpeg and /einloggen/
# stream.mjpeg onto these profiles via UNIFIX_STREAM_BACKEND_URL
# (typically http://127.0.0.1:1984). Authentication on the
# carvilon side is bearer (ESP) or session cookie (mieter); go2rtc
# itself stays unauthenticated on the loopback interface.

api:
  listen: ":1984"

streams:
  # Source profile - replace the URL with your actual UA Intercom
  # feed. The carvilon /a/streams page can update this live without
  # touching this file once the server is running.
  intercom_high:
    - "rtsps://192.168.1.1:7441/REPLACE_WITH_INTERCOM_STREAM_TOKEN"

  # ESP-Default. Width / height / frame-rate / quality optimised
  # for the 800x1280 ESP32-P4 LCD.
  intercom_esp:
    - "ffmpeg:intercom_high#video=mjpeg#width=800#height=1280#raw=-r 9 -q:v 6"

  # Browser-Default. Slightly smaller frames, slightly higher FPS
  # because browser playback can tolerate it.
  intercom_browser:
    - "ffmpeg:intercom_high#video=mjpeg#width=640#height=1024#raw=-r 12 -q:v 5"

# Optional: bind only to loopback so go2rtc is never reachable
# directly from the LAN. carvilon terminates the public endpoints
# and strips Authorization headers before forwarding.
rtsp:
  listen: "127.0.0.1:8554"

webrtc:
  listen: "127.0.0.1:8555"
