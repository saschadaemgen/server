# carvilon cloud (VPS) EnvironmentFile - systemd format.
# KEY=value, one per line, NO quotes, NO backslash continuations
# (this is NOT shell syntax). Lines starting with # are comments.
#
# Copy to carvilon-cloud.env next to the unit
# (/etc/systemd/system/carvilon-cloud.env), fill the <...> placeholder,
# then: chmod 0600 carvilon-cloud.env

CARVILON_SIDECHANNEL_LISTEN_ADDR=:8443
CARVILON_SIDECHANNEL_CA_CERT=/root/carvilon/certs/ca.crt
CARVILON_SIDECHANNEL_SERVER_CERT=/root/carvilon/certs/server.crt
CARVILON_SIDECHANNEL_SERVER_KEY=/root/carvilon/certs/server.key
# Activates the interim request-publish hook on loopback (the
# stream-chat trigger). Remove this line to keep the hook silent.
CARVILON_SIDECHANNEL_INTERNAL_ADDR=127.0.0.1:8445
# Currently unused on the cloud side (the cloud verifies no tokens yet),
# but set it now so a future verify path needs no redeploy. Must match
# the edge's CARVILON_PUBLISH_TOKEN_HMAC_KEY.
CARVILON_PUBLISH_TOKEN_HMAC_KEY=<32-byte-hex-publish-token-key>
