# carvilon cloud (VPS) EnvironmentFile - systemd format.
# KEY=value, one per line, NO quotes, NO backslash continuations
# (this is NOT shell syntax). Lines starting with # are comments.
#
# Copy to carvilon-cloud.env next to the unit
# (/etc/systemd/system/carvilon-cloud.env), fill the <...> placeholders,
# then: chmod 0600 carvilon-cloud.env
#
# Variables are read by config.FromEnv() and gated by ValidateCloud()
# (cloud role). The active lines are the side-channel baseline every
# cloud needs; the commented blocks (WHIP/WHEP stream, TURN relay) are
# the carvilon_stream-build features - uncomment + fill to enable. Real
# IPs/hosts are intentionally placeholders (never commit infra values).

# --- Side-channel server (REQUIRED for the cloud role; ValidateCloud) ---
# LISTEN_ADDR defaults to :8443 if unset. CA + server cert/key are
# mandatory (mTLS: the edge presents a client cert signed by this CA).
CARVILON_SIDECHANNEL_LISTEN_ADDR=:8443
CARVILON_SIDECHANNEL_CA_CERT=/root/carvilon/certs/ca.crt
CARVILON_SIDECHANNEL_SERVER_CERT=/root/carvilon/certs/server.crt
CARVILON_SIDECHANNEL_SERVER_KEY=/root/carvilon/certs/server.key
# Interim request-publish hook on loopback (the stream-chat trigger).
# OPTIONAL: remove/comment this line to keep the hook silent.
CARVILON_SIDECHANNEL_INTERNAL_ADDR=127.0.0.1:8445

# --- In-process WHIP/WHEP cloud stream (carvilon_stream build only) ---
# OPTIONAL, skip-or-start: with none of this set the VPS runs the
# side-channel ONLY. To enable, CERT + KEY must BOTH be set (ValidateCloud
# fails if only one is), and then CARVILON_PUBLISH_TOKEN_HMAC_KEY below
# becomes REQUIRED (the WHIP ingress verifies publish tokens with it).
# WHIP_LISTEN defaults to :8444 if unset.
#CARVILON_WHIP_LISTEN=:8444
#CARVILON_WHIP_CERT=/root/carvilon/certs/whip.crt
#CARVILON_WHIP_KEY=/root/carvilon/certs/whip.key
# publish-token verify key. MIRRORED: MUST be byte-identical to the
# edge's CARVILON_PUBLISH_TOKEN_HMAC_KEY (RPi mints, VPS verifies).
# Format: hex, 32 bytes -> openssl rand -hex 32. REQUIRED once the
# WHIP/WHEP stream above is enabled (ValidateCloud).
#CARVILON_PUBLISH_TOKEN_HMAC_KEY=<32-byte-hex-publish-token-key>
# egress-token verify key (mieter WHEP egress 401-verify). MIRRORED: MUST
# be byte-identical to the edge's CARVILON_EGRESS_TOKEN_HMAC_KEY (RPi
# mints, VPS verifies). Format: hex, 32 bytes -> openssl rand -hex 32.
# OPTIONAL: empty -> WHEP egress fails closed (401 for every subscriber);
# set-but-invalid -> boot error.
#CARVILON_EGRESS_TOKEN_HMAC_KEY=<32-byte-hex-egress-token-key>

# --- In-process TURN relay (carvilon_stream build only) ---
# OPTIONAL, gated INDEPENDENTLY of the WHIP/WHEP stream: set PUBLIC_IP +
# SHARED_SECRET to enable the relay (ValidateCloud then checks the IP form
# + port ranges). The TURN secret stays cloud-side only - the edge never
# holds it; it receives only short-lived credentials per request_publish.
#CARVILON_TURN_PUBLIC_IP=<vps-public-ip>
# High-entropy shared secret. NO format constraint in carvilon-server
# (consumed as a raw string); use a long random value, e.g.
# openssl rand -hex 32.
#CARVILON_TURN_SHARED_SECRET=<high-entropy-turn-secret>
# TURN realm. Defaults to "carvilon" when unset - do NOT change it (the
# credential minter is pinned to "carvilon").
#CARVILON_TURN_REALM=carvilon
# UDP relay port. Defaults to 3478 when unset (the CGNAT workhorse).
#CARVILON_TURN_UDP_PORT=3478
# turns: TLS relay port. OPT-IN: 0/unset = the TLS leg is OFF; set e.g.
# 5349 to enable it for networks that only allow outbound TLS.
#CARVILON_TURN_TLS_PORT=5349
# Public HOSTNAME the turns: leg is advertised on (only used when
# TLS_PORT > 0). Unset -> no turns: line. Placeholder, NOT the real domain.
#CARVILON_TURN_PUBLIC_HOST=<turns-host>
# Cert/key for the turns: TLS leg, SEPARATE from the WHIP certs (e.g. a
# Let's Encrypt cert for the turns host). Unset -> falls back to the WHIP
# cert/key (dev / single-cert setups). The WHIP ingress always stays on
# the private cloudca.
#CARVILON_TURN_TLS_CERT=/root/carvilon/certs/turns.crt
#CARVILON_TURN_TLS_KEY=/root/carvilon/certs/turns.key
