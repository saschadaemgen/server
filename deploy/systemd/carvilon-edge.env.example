# carvilon edge (RPi) EnvironmentFile - systemd format.
# KEY=value, one per line, NO quotes, NO backslash continuations
# (this is NOT shell syntax). Lines starting with # are comments.
#
# Copy to carvilon-edge.env next to the unit
# (~/.config/systemd/user/carvilon-edge.env), fill the <...>
# placeholders, then: chmod 0600 carvilon-edge.env
#
# Variables are read by config.FromEnv() and gated by Validate() (edge
# role). The active lines are what this RPi deployment needs; the
# commented blocks are optional features - uncomment + fill to enable.
#
# UNIFIX_* are the legacy aliases of the CARVILON_* names; both are
# accepted (config.lookupEnv / secrets.New fall back to them). They are
# kept here to match the RPi's existing setup. CARVILON_* is canonical.
# Real IPs are intentionally placeholders (never commit infra values).

# --- Core (edge) ---
# SECRETS_KEY is REQUIRED: the edge will not start without it (it
# encrypts the viewer pepper + stored secrets). 32-byte hex.
UNIFIX_SECRETS_KEY=<32-byte-hex-master-key>
# DEV_MODE=1 serves plain HTTP and drops the Secure cookie flag. Unset it
# for TLS mode - then CARVILON_CERT_FILE + CARVILON_KEY_FILE below become
# REQUIRED (Validate).
UNIFIX_DEV_MODE=1
UNIFIX_LISTEN_ADDR=:9080
# IPv4 the mock viewers announce + the mDNS record. Empty -> mocks are
# unreachable by the UDM (warned, not fatal).
UNIFIX_SERVER_IPV4=<rpi-lan-ip>
UNIFIX_DB_PATH=/home/sash710/carvilon-server/state/carvilon.db
UNIFIX_MOCK_STATE_DIR=/home/sash710/carvilon-server/state/mocks
UNIFIX_STREAM_BACKEND_URL=http://127.0.0.1:8555
# TLS mode only (DEV_MODE unset): the edge HTTP server's cert + key, plus
# the externally visible base URL. Leave commented while DEV_MODE=1.
#CARVILON_CERT_FILE=/home/sash710/carvilon-server/certs/edge.crt
#CARVILON_KEY_FILE=/home/sash710/carvilon-server/certs/edge.key
#CARVILON_BASE_URL=https://<rpi-lan-ip>:9080

# --- Side-channel client (edge dials the cloud; ADDITIVE) ---
# All optional: an edge with none of these runs fully LAN-local. But once
# DIAL_URL is set, CARVILON_PUBLISH_TOKEN_HMAC_KEY below becomes REQUIRED
# (Validate). The host in DIAL_URL must match the server cert's IP SAN.
CARVILON_SIDECHANNEL_DIAL_URL=wss://<vps-public-ip>:8443/sidechannel
CARVILON_SIDECHANNEL_CA_CERT=/home/sash710/carvilon-server/certs/ca.crt
CARVILON_SIDECHANNEL_CLIENT_CERT=/home/sash710/carvilon-server/certs/client.crt
CARVILON_SIDECHANNEL_CLIENT_KEY=/home/sash710/carvilon-server/certs/client.key
# Static cloud WHIP ingress the edge pushes to (carvilon_stream build).
# OPTIONAL but needed for the cloud push to work; the path is defined by
# the stream-cloud WHIP server. Unused in the public build.
#CARVILON_SIDECHANNEL_CLOUD_WHIP_URL=https://<vps-public-ip>:8444/<whip-path>

# --- Stream tokens (MIRRORED edge <-> cloud) ---
# publish-token signing key. MIRRORED: MUST be byte-identical to the
# cloud's CARVILON_PUBLISH_TOKEN_HMAC_KEY (RPi mints, VPS verifies).
# Format: hex, 32 bytes -> openssl rand -hex 32.
# REQUIRED here because the side-channel DIAL_URL above is set (Validate).
CARVILON_PUBLISH_TOKEN_HMAC_KEY=<32-byte-hex-publish-token-key>
# egress-token signing key (mieter WHEP egress). MIRRORED: MUST be
# byte-identical to the cloud's CARVILON_EGRESS_TOKEN_HMAC_KEY (RPi mints
# at /webviewer/egress-token, VPS verifies). Format: hex, 32 bytes ->
# openssl rand -hex 32. OPTIONAL: unset -> /webviewer/egress-token
# soft-503s; set-but-invalid -> boot error. Uncomment + fill to enable.
#CARVILON_EGRESS_TOKEN_HMAC_KEY=<32-byte-hex-egress-token-key>

# FCM doorbell push (optional, edge only). Both or neither - setting
# exactly one is a config error. Both empty = FCM disabled, the edge
# starts normally and the push leg skips. The RPi calls Google
# directly (not via the cloud / side-channel).
#CARVILON_FCM_SERVICE_ACCOUNT_JSON=/home/sash710/carvilon-server/certs/fcm-service-account.json
#CARVILON_FCM_PROJECT_ID=<firebase-project-id>

# In-process stream server (carvilon_stream build only). The commercial
# build embeds the streaming-server in this process: it serves the local
# MJPEG/Offer HTTP path on CARVILON_STREAM_ADDR and reuses
# UNIFIX_STREAM_BACKEND_URL above as its base URL. NVR_HOST/API_KEY/
# DB_PATH/ADDR (+ the backend URL) are all required to enable it;
# incomplete config skips it and the edge keeps running. The public
# build ignores these entirely.
# CARVILON_STREAM_API_KEY is a SECRET (Protect X-API-KEY) - keep this
# file 0600.
#CARVILON_STREAM_NVR_HOST=<udm-protect-host>
#CARVILON_STREAM_API_KEY=<protect-api-key>
#CARVILON_STREAM_DB_PATH=/home/sash710/carvilon-server/state/stream.db
#CARVILON_STREAM_ADDR=:8555
#CARVILON_STREAM_ENCRYPTION=tls
#CARVILON_STREAM_ENABLE_MJPEG=1
#CARVILON_STREAM_FFMPEG_PATH=
